    <bpmn:serviceTask id="Activity_0p6fmth" name="Send Order Executed Email" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="camunda-noreply@1oannis.com" target="authentication.username" />
          <zeebe:input source="password" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="mail.1oannis.com" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=465" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="SSL" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="camunda-noreply@1oannis.com" target="data.smtpAction.from" />
          <zeebe:input source="info@1oannis.com" target="data.smtpAction.to" />
          <zeebe:input source="Cryptoflow - Order Executed" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=&#34;Transaction: &#34; + transactionId + &#34; was executed successfully.\n\nSymbol:\t\t&#34; + symbol + &#34;\nAmount:\t\t&#34; + amount + &#34;\nPrice:\t\t\t&#34; + matchedPrice + &#34;\n\nThe order was placed at a target price of &#34; + price + &#34; and matched at &#34; +&#10;   matchedPrice + &#34;.&#34;" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1n672u3</bpmn:incoming>
      <bpmn:outgoing>Flow_1lf8liz</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_06aqhe0">
      <bpmn:incoming>Flow_1lf8liz</bpmn:incoming>
    </bpmn:endEvent>
