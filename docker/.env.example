# ──────────────────────────────────────────────────────────────────────────────
# CryptoFlow – Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# docker compose automatically reads .env from the same directory.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=cryptoflow
POSTGRES_USER=cryptoflow
POSTGRES_PASSWORD=cryptoflow

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@cryptoflow.com
PGADMIN_DEFAULT_PASSWORD=admin

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Binance (Market Data Service) ────────────────────────────────────────────
BINANCE_STREAM_URL=wss://stream.binance.com:9443/ws

# ── Camunda 8 SaaS (Transaction Service) ─────────────────────────────────────
CAMUNDA_CLIENT_ID_TRANSACTION_SERVICE=your-client-id
CAMUNDA_CLIENT_SECRET_TRANSACTION_SERVICE=your-client-secret
CAMUNDA_CLUSTER_ID_TRANSACTION_SERVICE=your-cluster-id
CAMUNDA_REGION_TRANSACTION_SERVICE=lhr-1

# ── Camunda 8 SaaS (User Service) ────────────────────────────────────────────
CAMUNDA_CLIENT_ID_USER_SERVICE=your-client-id
CAMUNDA_CLIENT_SECRET_USER_SERVICE=your-client-secret
CAMUNDA_CLUSTER_ID_USER_SERVICE=your-cluster-id
CAMUNDA_REGION_USER_SERVICE=lhr-1

# ── Camunda 8 SaaS (Portfolio Service) ────────────────────────────────────────────
CAMUNDA_CLIENT_ID_PORTFOLIO_SERVICE=your-client-id
CAMUNDA_CLIENT_SECRET_PORTFOLIO_SERVICE=your-client-secret
CAMUNDA_CLUSTER_ID_PORTFOLIO_SERVICE=your-cluster-id
CAMUNDA_REGION_PORTFOLIO_SERVICE=lhr-1

# ── Camunda 8 SaaS (Onboarding Service) ────────────────────────────────────────────
CAMUNDA_CLIENT_ID_ONBOARDING_SERVICE=your-client-id
CAMUNDA_CLIENT_SECRET_ONBOARDING_SERVICE=your-client-secret
CAMUNDA_CLUSTER_ID_ONBOARDING_SERVICE=your-cluster-id
CAMUNDA_REGION_ONBOARDING_SERVICE=lhr-1