@startuml context-map-detailed
skinparam backgroundColor transparent
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultTextAlignment center
skinparam rectangleBorderColor #78909C
skinparam rectangleBackgroundColor #FAFAFA
skinparam componentBorderColor #78909C
skinparam cloudBorderColor #78909C
skinparam actorBorderColor #37474F
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #BDBDBD
skinparam ArrowColor #546E7A
skinparam ArrowFontColor #37474F
skinparam ArrowFontSize 11

actor "End user" as User
cloud "Binance feeds\n(external market source)" as Binance #FFF3E0
cloud "FX provider\n(external reference source)" as FxProvider #E0F7FA
cloud "CoinGecko\n(external metadata source)" as CoinGecko #E0F2F1
cloud "Camunda 8\norchestration" as Camunda #E3F2FD

rectangle "CryptoFlow platform" as Platform #F5F5F5 {
    rectangle "Market data services" as Market #FFFDE7 {
        component "market-data-service" as MD #FFF8E1
        component "market-partial-book-ingestion-service" as MPBI #FFF8E1
        component "market-order-scout-service" as MOS #FFF8E1
    }

    rectangle "Reference data services" as Reference #E0F7FA {
        component "fx-rate-service" as FX #E0F7FA
        component "coin-metadata-service" as CMS #E0F2F1
    }

    queue "Kafka event backbone\nprice, reference, identity, scout,\norder, compensation topics" as Kafka #ECEFF1

    rectangle "Process and domain services" as Domain #F5F5F5 {
        component "onboarding-service" as ONB #EDE7F6
        component "user-service" as US #FCE4EC
        component "transaction-service" as TR #E3F2FD
        component "portfolio-service" as PF #E8F5E9
    }
}

note bottom of Platform
  **shared-events** module
  Kafka event contracts shared by
  platform services
end note

Binance --> MD
Binance --> MPBI
FxProvider --> FX
CoinGecko --> CMS
User --> Camunda : Tasklist forms

MD --> Kafka : price topics
MPBI --> Kafka : raw scout topic
Kafka --> MOS : raw scout topic
MOS --> Kafka : derived scout topics
FX --> Kafka : FX rates
CMS --> Kafka : coin metadata

US --> Kafka : identity + display currency
TR --> Kafka : buy bids + approved orders
PF --> Kafka : compensation

Kafka --> MD : reference metadata
Kafka --> TR : users, prices, FX,\nmatchable asks
Kafka --> PF : prices, FX,\norders, preferences
Kafka --> US : compensation

ONB .up.> Camunda : deploys userOnboarding
TR ..> Camunda : deploys placeOrder
Camunda ..> US : onboarding jobs
Camunda ..> PF : onboarding jobs
Camunda ...> TR : order jobs

@enduml
