    <bpmn:sequenceFlow id="Flow_0iqvkoz" sourceRef="Gateway_11awx1l" targetRef="Activity_CreatePortfolio" />
    <bpmn:parallelGateway id="Gateway_0rf49r5" name="User &#38; Portfolio Created">
      <bpmn:incoming>Flow_0envu1g</bpmn:incoming>
      <bpmn:incoming>Flow_11aj02o</bpmn:incoming>
      <bpmn:outgoing>Flow_1v0v7cr</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_0envu1g" sourceRef="Activity_CreateUser" targetRef="Gateway_0rf49r5" />
    <bpmn:sequenceFlow id="Flow_11aj02o" sourceRef="Activity_CreatePortfolio" targetRef="Gateway_0rf49r5" />
    <bpmn:sequenceFlow id="Flow_1v0v7cr" sourceRef="Gateway_0rf49r5" targetRef="Event_ProcessEnd" />
  </bpmn:process>
